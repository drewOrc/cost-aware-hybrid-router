{
  "_meta": {
    "description": "CLINC150 的 151 個 intent 映射到 7 個 agent 類別",
    "agents": [
      "finance_agent — 銀行、信用卡、帳戶、帳單、稅務",
      "travel_agent — 機票、飯店、簽證、行李、預約餐廳",
      "auto_agent — 車輛保養、加油、租車、交通、導航",
      "kitchen_agent — 食譜、營養、食材、餐廳推薦、購物清單",
      "productivity_agent — 行事曆、提醒、待辦、PTO、會議、計算、翻譯、天氣",
      "device_agent — 智慧家居、音樂、裝置設定、音量、語言",
      "meta_agent — 問候、閒聊、機器人身份、笑話、是/否/取消"
    ],
    "oos_handling": "oos (out-of-scope) 標為 'oos'，不屬於任何 agent"
